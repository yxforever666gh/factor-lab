{
  "version": 1,
  "name": "openclaw_candidate_generation_policy",
  "mission": "基于稳定候选、高价值失败、family 缺口与互补性，持续生成少而精的新候选因子。",
  "budgets": {
    "stable_neighbor": 2,
    "failure_driven": 2,
    "template_driven": 2,
    "family_gap": 1
  },
  "enabled_operators": [
    "combine_add",
    "combine_sub",
    "combine_ratio",
    "combine_mul",
    "combine_avg",
    "combine_primary_bias",
    "residualize_against_peer",
    "orthogonalize_against_peer"
